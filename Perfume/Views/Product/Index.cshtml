@model IEnumerable<Perfume.Models.Products>

@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_LayoutPageMain.cshtml";


}
<link href="~/Content/MainStyles.css" rel="stylesheet" />
<link href="~/Content/ResponsiveStyle.css" rel="stylesheet" />
<link href="~/Content/bootstrap.css" rel="stylesheet" />
<link href="~/Content/bootstrap.min.css" rel="stylesheet" />
<style>
    .btn {
        padding: 15px 30px;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        font-size: 1rem;
        transition: all 0.3s ease;
        text-decoration: none;
    }

    .btn-primary {
        background-color: beige;
        color: #04086c;
    }
    .carbon-header a {
        font-size: xx-large;
        padding: 0.4rem 2rem;
        border-radius: 5px;
        color: darkred;
        background-color: beige;
    }
</style>
<h2>Danh Sách Sản Phẩm</h2>
<div class="carbon-container"style="padding-top:10rem">
    <div class="carbon-header">
        <h2>
            @if (Session["NameUser"] == null)
            {
                <span>Bạn chưa đăng nhập</span>
            }
            else
            {
                <span>Xin chào @Session["NameUser"]</span>
            }
        </h2>
        <p style="padding:1rem 2rem">
            <a href="@Url.Action("Logout","LoginRegister")">
                <i class="fa-solid fa-arrow-right-from-bracket" ></i>
            </a>
        </p>
    </div>
</div>
@Html.ActionLink("Thêm Mới Sản Phẩm", "Create", null, new { @class = "btn btn-sucess" })
@using (Html.BeginForm("Index", "Product", FormMethod.Get))
{
    <div class="filter-section">

        <div class="form-group">
            <label>Giá từ:</label>
            <input type="number" name="_min" value="1" class="form-control" style="width: 150px; display: inline-block;" />
        </div>

        <div class="form-group">
            <label>Đến:</label>
            <input type="number" name="_max" value="1" class="form-control" style="width: 150px; display: inline-block;" />
        </div>

        <div class="form-group">
            <label>Danh mục:</label>
            @Html.DropDownList("_category", ViewBag.Categories as SelectList, "Tất cả danh mục", new { @class = "form-control", style = "width: 200px; display: inline-block;" })
        </div>

        <input type="submit" value="Chọn Lọc" />
    </div>

}
<table class="table">
    <tr>
        <th>@Html.DisplayNameFor(m => m.ProductID)</th>
        <th>@Html.DisplayNameFor(m => m.NamePro)</th>
        <th>@Html.DisplayNameFor(m => m.DecriptionPro)</th>
        <th>@Html.DisplayNameFor(m => m.Price)</th>
        @*<th>@Html.DisplayNameFor(m => m.IDCate)</th>*@
        <th>@Html.DisplayNameFor(m => m.ImagePro)</th>
        <td></td>
    </tr>
    @foreach (var pro in Model)
    {
        <tr>
            <td>@Html.DisplayFor(m => pro.ProductID)</td>
            <td>@Html.DisplayFor(m => pro.NamePro)</td>
            <td>@Html.DisplayFor(m => pro.DecriptionPro)</td>
            <td>@Html.DisplayFor(m => pro.Price)</td>
            @*<td>@Html.DisplayFor(m => pro.IDCate)</td>*@
            @*<td>@Html.DisplayFor(m => pro.ImagePro)</td>*@
            <td>
                <img src="@Url.Content(pro.ImagePro)" width="100" height="100" />
            </td>
            <td>
                @Html.ActionLink("Sửa", "Edit", new { id = pro.ProductID }, new { @class = "btn btn-warning" })
                @Html.ActionLink("Xóa", "Xoa", new { id = pro.ProductID }, new { @class = "btn btn-dark" })
            </td>
        </tr>

    }
</table>

